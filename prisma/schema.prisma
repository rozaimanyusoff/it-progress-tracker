generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       Int             @id @default(autoincrement())
  name                     String
  email                    String          @unique
  password_hash            String?
  role                     Role            @default(member)
  initials                 String?
  contact_number           String?
  avatar_url               String?
  is_active                Boolean         @default(false)
  activation_token         String?         @unique
  activation_token_expiry  DateTime?
  created_at               DateTime        @default(now())
  unit_id                  Int?
  dept_id                  Int?
  company_id               Int?
  unit                     OrgUnit?        @relation(fields: [unit_id], references: [id], onDelete: SetNull)
  department               Department?     @relation(fields: [dept_id], references: [id], onDelete: SetNull)
  company                  Company?        @relation(fields: [company_id], references: [id], onDelete: SetNull)
  project_assignments      ProjectAssignee[]
  updates                  ProjectUpdate[]
  issues                   Issue[]
  assigned_issues          Issue[]         @relation("IssueAssignee")
  audit_logs               AuditLog[]
  feature_assignments      FeatureDeveloper[]
  created_features         Feature[]          @relation("FeatureCreator")
  assigned_tasks           Task[]             @relation("TaskAssignee")
  status_updated_tasks     Task[]             @relation("TaskStatusUpdater")
  task_updates             TaskUpdate[]
  task_history             TaskHistory[]
  resolved_issues          Issue[]        @relation("IssueResolver")
  issue_history            IssueHistory[] @relation("IssueHistoryUser")
}

model OrgUnit {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())
  users      User[]
}

model Department {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())
  users      User[]
}

model Company {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())
  users      User[]
}

model Project {
  id                Int               @id @default(autoincrement())
  title             String
  description       String?
  start_date        DateTime
  deadline          DateTime
  status            ProjectStatus     @default(Pending)
  category          ProjectCategory   @default(NonClaimable)
  actual_start      DateTime?
  actual_end        DateTime?
  health_status     HealthStatus?
  created_at        DateTime          @default(now())
  updates           ProjectUpdate[]
  issues            Issue[]
  modules           Module[]
  assignees         ProjectAssignee[]
  feature_links     ProjectFeature[]
  deliverables      Deliverable[]
}

model Module {
  id            Int              @id @default(autoincrement())
  project_id    Int
  title         String
  description   String?
  start_date    DateTime?
  end_date      DateTime?
  order         Int              @default(0)
  created_at    DateTime         @default(now())
  project       Project          @relation(fields: [project_id], references: [id], onDelete: Cascade)
  feature_links ProjectFeature[]
  deliverables  Deliverable[]
}

model ProjectFeature {
  project_id  Int
  feature_id  Int
  module_id   Int?
  assigned_at DateTime @default(now())
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  feature     Feature  @relation(fields: [feature_id], references: [id], onDelete: Cascade)
  module      Module?  @relation(fields: [module_id], references: [id], onDelete: SetNull)

  @@id([project_id, feature_id])
}

model Deliverable {
  id                  Int           @id @default(autoincrement())
  project_id          Int
  module_id           Int?
  title               String
  description         String?
  status              FeatureStatus @default(Pending)
  mandays             Int           @default(0)
  planned_start       DateTime?
  planned_end         DateTime?
  actual_start        DateTime?
  actual_end          DateTime?
  is_actual_override  Boolean       @default(false)
  order               Int           @default(0)
  created_at          DateTime      @default(now())
  project      Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  module       Module?       @relation(fields: [module_id], references: [id], onDelete: SetNull)
  tasks        Task[]
  issues       Issue[]
}

model ProjectAssignee {
  project_id  Int
  user_id     Int
  assigned_at DateTime @default(now())
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id])

  @@id([project_id, user_id])
}

model ProjectUpdate {
  id           Int           @id @default(autoincrement())
  project_id   Int
  user_id      Int
  progress_pct Int
  status       UpdateStatus
  notes        String?
  created_at   DateTime      @default(now())
  project      Project       @relation(fields: [project_id], references: [id])
  user         User          @relation(fields: [user_id], references: [id])
}

model Issue {
  id              Int           @id @default(autoincrement())
  project_id      Int
  user_id         Int
  assignee_id     Int?
  resolved_by_id  Int?
  deliverable_id  Int?
  task_id         Int?
  title           String
  description     String?
  severity        Severity      @default(medium)
  resolved        Boolean       @default(false)
  issue_type      IssueType     @default(bug)
  issue_severity  IssueSeverity @default(moderate)
  issue_status    IssueStatus   @default(open)
  due_date        DateTime?
  resolution_note String?
  resolved_at     DateTime?
  media_urls      String[]
  created_at      DateTime      @default(now())
  project         Project       @relation(fields: [project_id], references: [id])
  user            User          @relation(fields: [user_id], references: [id])
  assignee        User?         @relation("IssueAssignee", fields: [assignee_id], references: [id])
  resolved_by     User?         @relation("IssueResolver", fields: [resolved_by_id], references: [id])
  deliverable     Deliverable?  @relation(fields: [deliverable_id], references: [id], onDelete: SetNull)
  task            Task?         @relation(fields: [task_id], references: [id], onDelete: SetNull)
  history         IssueHistory[]
}

model IssueHistory {
  id          Int      @id @default(autoincrement())
  issue_id    Int
  changed_by  Int
  action      String
  from_value  String?
  to_value    String?
  note        String?
  created_at  DateTime @default(now())
  issue       Issue    @relation(fields: [issue_id], references: [id], onDelete: Cascade)
  user        User     @relation("IssueHistoryUser", fields: [changed_by], references: [id])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  user_id     Int
  action      String
  target_type String
  target_id   Int
  metadata    Json?
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id])
}

enum Role {
  manager
  member
}

enum ProjectStatus {
  Pending
  InProgress
  Done
  OnHold
}

enum ProjectCategory {
  Claimable
  NonClaimable
}

enum UpdateStatus {
  InProgress
  Done
  OnHold
  Pending
}

enum Severity {
  low
  medium
  high
}

enum IssueSeverity {
  minor
  moderate
  major
  critical
}

enum IssueType {
  bug
  enhancement
  clarification
}

enum IssueStatus {
  open
  in_progress
  resolved
  closed
}

enum FeatureStatus {
  Pending
  InProgress
  Done
  OnHold
}

enum TaskStatus {
  Todo
  InProgress
  InReview
  Done
  Blocked
}

enum HealthStatus {
  on_track
  at_risk
  delayed
  overdue
}

enum TaskPriority {
  low
  medium
  high
  critical
}

model Feature {
  id             Int               @id @default(autoincrement())
  title          String
  description    String?
  mandays        Int               @default(0)
  status         FeatureStatus     @default(Pending)
  actual_start   DateTime?
  actual_end     DateTime?
  order          Int               @default(0)
  created_at     DateTime          @default(now())
  created_by_id  Int
  created_by     User              @relation("FeatureCreator", fields: [created_by_id], references: [id])
  developers     FeatureDeveloper[]
  tasks          Task[]
  project_links  ProjectFeature[]
}

model FeatureDeveloper {
  feature_id  Int
  user_id     Int
  assigned_at DateTime  @default(now())
  feature     Feature   @relation(fields: [feature_id], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [user_id], references: [id])

  @@id([feature_id, user_id])
}

model Task {
  id                 Int           @id @default(autoincrement())
  feature_id         Int?
  deliverable_id     Int?
  title              String
  description        String?
  status             TaskStatus    @default(Todo)
  assigned_to        Int?
  order              Int           @default(0)
  is_predefined      Boolean       @default(false)
  actual_start       DateTime?
  actual_end         DateTime?
  time_started_at    DateTime?
  time_spent_seconds Int           @default(0)
  review_count       Int           @default(0)
  created_at         DateTime      @default(now())
  due_date           DateTime?
  est_mandays        Decimal?      @db.Decimal(4, 1)
  priority           TaskPriority  @default(medium)
  is_blocked         Boolean       @default(false)
  blocked_reason     String?       @db.VarChar(500)
  started_at         DateTime?
  submitted_at       DateTime?
  completed_at       DateTime?
  status_updated_at  DateTime?
  status_updated_by  Int?
  feature            Feature?      @relation(fields: [feature_id], references: [id], onDelete: Cascade)
  deliverable        Deliverable?  @relation(fields: [deliverable_id], references: [id], onDelete: Cascade)
  assignee           User?         @relation("TaskAssignee", fields: [assigned_to], references: [id])
  status_updater     User?         @relation("TaskStatusUpdater", fields: [status_updated_by], references: [id])
  task_updates       TaskUpdate[]
  task_history       TaskHistory[]
  issues             Issue[]
}

model TaskHistory {
  id           Int        @id @default(autoincrement())
  task_id      Int
  changed_by   Int
  from_status  String?
  to_status    String
  actual_date  DateTime?
  note         String?
  is_auto_log  Boolean    @default(true)
  created_at   DateTime   @default(now())
  task         Task       @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [changed_by], references: [id])
}


model AppSetting {
  key        String   @id
  value      String
  updated_at DateTime @default(now()) @updatedAt
}

model DeliverableRecord {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  description String?
  created_at  DateTime @default(now())
}

model TaskUpdate {
  id         Int      @id @default(autoincrement())
  task_id    Int
  user_id    Int
  notes      String?
  media_urls String[]
  created_at DateTime @default(now())
  task       Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id])
}
