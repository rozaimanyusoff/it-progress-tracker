generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Unit {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  users    User[]
  projects Project[]
}

model User {
  id                       Int             @id @default(autoincrement())
  name                     String
  email                    String          @unique
  password_hash            String?
  role                     Role            @default(member)
  unit_id                  Int?
  is_active                Boolean         @default(false)
  activation_token         String?         @unique
  activation_token_expiry  DateTime?
  created_at               DateTime        @default(now())
  unit                     Unit?           @relation(fields: [unit_id], references: [id])
  projects                 Project[]       @relation("ProjectOwner")
  updates                  ProjectUpdate[]
  issues                   Issue[]
  audit_logs               AuditLog[]
}

model Project {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  unit_id     Int
  owner_id    Int
  start_date  DateTime
  deadline    DateTime
  status      ProjectStatus   @default(Pending)
  created_at  DateTime        @default(now())
  unit        Unit            @relation(fields: [unit_id], references: [id])
  owner       User            @relation("ProjectOwner", fields: [owner_id], references: [id])
  updates     ProjectUpdate[]
  issues      Issue[]
}

model ProjectUpdate {
  id           Int           @id @default(autoincrement())
  project_id   Int
  user_id      Int
  progress_pct Int
  status       UpdateStatus
  notes        String?
  created_at   DateTime      @default(now())
  project      Project       @relation(fields: [project_id], references: [id])
  user         User          @relation(fields: [user_id], references: [id])
}

model Issue {
  id          Int           @id @default(autoincrement())
  project_id  Int
  user_id     Int
  title       String
  description String?
  severity    Severity      @default(medium)
  resolved    Boolean       @default(false)
  created_at  DateTime      @default(now())
  project     Project       @relation(fields: [project_id], references: [id])
  user        User          @relation(fields: [user_id], references: [id])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  user_id     Int
  action      String
  target_type String
  target_id   Int
  metadata    Json?
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id])
}

enum Role {
  manager
  member
}

enum ProjectStatus {
  Pending
  InProgress
  Done
  OnHold
}

enum UpdateStatus {
  InProgress
  Done
  OnHold
  Pending
}

enum Severity {
  low
  medium
  high
}
