generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Unit {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  users    User[]
  projects Project[]
}

model User {
  id                       Int             @id @default(autoincrement())
  name                     String
  email                    String          @unique
  password_hash            String?
  role                     Role            @default(member)
  unit_id                  Int?
  is_active                Boolean         @default(false)
  activation_token         String?         @unique
  activation_token_expiry  DateTime?
  created_at               DateTime        @default(now())
  unit                     Unit?              @relation(fields: [unit_id], references: [id])
  projects                 Project[]          @relation("ProjectOwner")
  updates                  ProjectUpdate[]
  issues                   Issue[]
  audit_logs               AuditLog[]
  feature_assignments      FeatureDeveloper[]
  created_features         Feature[]          @relation("FeatureCreator")
  assigned_tasks           Task[]             @relation("TaskAssignee")
}

model Project {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  unit_id     Int
  owner_id    Int
  start_date  DateTime
  deadline    DateTime
  status      ProjectStatus   @default(Pending)
  created_at  DateTime        @default(now())
  unit        Unit            @relation(fields: [unit_id], references: [id])
  owner       User            @relation("ProjectOwner", fields: [owner_id], references: [id])
  updates     ProjectUpdate[]
  issues      Issue[]
  features    Feature[]
}

model ProjectUpdate {
  id           Int           @id @default(autoincrement())
  project_id   Int
  user_id      Int
  progress_pct Int
  status       UpdateStatus
  notes        String?
  created_at   DateTime      @default(now())
  project      Project       @relation(fields: [project_id], references: [id])
  user         User          @relation(fields: [user_id], references: [id])
}

model Issue {
  id          Int           @id @default(autoincrement())
  project_id  Int
  user_id     Int
  title       String
  description String?
  severity    Severity      @default(medium)
  resolved    Boolean       @default(false)
  created_at  DateTime      @default(now())
  project     Project       @relation(fields: [project_id], references: [id])
  user        User          @relation(fields: [user_id], references: [id])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  user_id     Int
  action      String
  target_type String
  target_id   Int
  metadata    Json?
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id])
}

enum Role {
  manager
  member
}

enum ProjectStatus {
  Pending
  InProgress
  Done
  OnHold
}

enum UpdateStatus {
  InProgress
  Done
  OnHold
  Pending
}

enum Severity {
  low
  medium
  high
}

enum FeatureStatus {
  Pending
  InProgress
  Done
  OnHold
}

enum TaskStatus {
  Todo
  InProgress
  InReview
  Done
}

model Feature {
  id             Int               @id @default(autoincrement())
  project_id     Int
  title          String
  description    String?
  mandays        Int               @default(0)
  status         FeatureStatus     @default(Pending)
  planned_start  DateTime
  planned_end    DateTime
  actual_start   DateTime?
  actual_end     DateTime?
  order          Int               @default(0)
  created_at     DateTime          @default(now())
  created_by_id  Int
  project        Project           @relation(fields: [project_id], references: [id])
  created_by     User              @relation("FeatureCreator", fields: [created_by_id], references: [id])
  developers     FeatureDeveloper[]
  tasks          Task[]
}

model FeatureDeveloper {
  feature_id  Int
  user_id     Int
  assigned_at DateTime  @default(now())
  feature     Feature   @relation(fields: [feature_id], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [user_id], references: [id])

  @@id([feature_id, user_id])
}

model Task {
  id            Int        @id @default(autoincrement())
  feature_id    Int
  title         String
  description   String?
  status        TaskStatus @default(Todo)
  assigned_to   Int?
  order         Int        @default(0)
  is_predefined Boolean    @default(false)
  actual_start  DateTime?
  actual_end    DateTime?
  created_at    DateTime   @default(now())
  feature       Feature    @relation(fields: [feature_id], references: [id], onDelete: Cascade)
  assignee      User?      @relation("TaskAssignee", fields: [assigned_to], references: [id])
}
