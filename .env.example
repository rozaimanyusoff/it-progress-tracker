DATABASE_URL="postgresql://postgres:password@localhost:5432/it_tracker"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-change-in-production"  # openssl rand -base64 32

# Gmail SMTP
# SMTP_PASS must be a Google App Password — NOT your Gmail login password.
# Gmail blocks regular passwords when 2-Step Verification is enabled.
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
SMTP_FROM="IT Tracker <your-email@gmail.com>"
